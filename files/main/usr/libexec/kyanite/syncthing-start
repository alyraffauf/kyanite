#!/usr/bin/env bash
# Stage the Syncthing quadlet into the user's session if not already present,
# then ensure the service is running. Idempotent — safe to run multiple times.
# Invoked by syncthing-start.desktop and ujust enable-syncthing.

set -euo pipefail

QUADLET_SRC=/usr/share/kyanite/quadlets/syncthing.container
QUADLET_DEST="$HOME/.config/containers/systemd/syncthing.container"

mkdir -p "$(dirname "$QUADLET_DEST")"
[ -f "$QUADLET_DEST" ] || cp "$QUADLET_SRC" "$QUADLET_DEST"

systemctl --user daemon-reload
systemctl --user unmask syncthing.service 2>/dev/null || true
systemctl --user start syncthing.service
